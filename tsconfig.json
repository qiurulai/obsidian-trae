{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ES2018",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2018", "DOM.Iterable"],
    "types": ["node"],
    "noImplicitAny": true
  },
  "include": ["src/**/*.ts"]
}
